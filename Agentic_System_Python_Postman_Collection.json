{
  "info": {
    "_postman_id": "agentic-system-python-v1",
    "name": "Agentic System - Python (Scalable 100+ Tools)",
    "description": "Complete test suite for the Python Agentic System.\n\nHow to use:\n1. Start the server: python main.py\n2. Set environment variable base_url = http://127.0.0.1:8000\n3. For multi-step flows (e.g. create invoice → send invoice), use the SAME session_id across requests\n4. Run requests in folder order for best demo flow\n\nDomains covered:\n- E-commerce (FakeStore API)\n- PayPal (Sandbox)\n- RAG / Knowledge Base\n- System Tools",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "session_id",
      "value": "demo-session-1",
      "type": "string"
    }
  ],
